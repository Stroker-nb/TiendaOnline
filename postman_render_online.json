{
  "info": {
    "name": "TiendaOnline - Gateway ",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "gateway_url",
      "value": "http://localhost:8080"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [

    {
      "name": "00 Login (Auth)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"123456\"\n}"
        },
        "url": "{{gateway_url}}/api/v1/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "pm.environment.set('token', jsonData.token);"
            ]
          }
        }
      ]
    },

    {
      "name": "01 Cliente - Listar (PROTEGIDO)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{gateway_url}}/api/v1/clientes"
      }
    },

    {
      "name": "02 Producto - Listar",
      "request": {
        "method": "GET",
        "url": "{{gateway_url}}/api/v1/productos"
      }
    },

    {
      "name": "03 Pedido - Listar",
      "request": {
        "method": "GET",
        "url": "{{gateway_url}}/api/v1/pedidos"
      }
    },

    {
      "name": "04 Pago - Listar",
      "request": {
        "method": "GET",
        "url": "{{gateway_url}}/api/v1/pagos"
      }
    },

    {
      "name": "05 Envio - Listar",
      "request": {
        "method": "GET",
        "url": "{{gateway_url}}/api/v1/envios"
      }
    },

    {
      "name": "06 Auth - Perfil / usuarios (GET si existe)",
      "request": {
        "method": "GET",
        "url": "{{gateway_url}}/api/v1/auth"
      }
    },

    {
      "name": "07 Resena - Listar",
      "request": {
        "method": "GET",
        "url": "{{gateway_url}}/api/v1/resenas"
      }
    },

    {
      "name": "08 Distribuidor - Listar",
      "request": {
        "method": "GET",
        "url": "{{gateway_url}}/api/v1/distribuidores"
      }
    },

    {
      "name": "09 Sucursal - Listar",
      "request": {
        "method": "GET",
        "url": "{{gateway_url}}/api/v1/sucursales"
      }
    },

    {
      "name": "10 Trabajador - Listar",
      "request": {
        "method": "GET",
        "url": "{{gateway_url}}/api/v1/trabajadores"
      }
    }

  ]
}